# ============================================================================
# WebDAV Server – Go implementation
# Copy this file to .env and adjust values before starting.
# ============================================================================

# ---- Server ----------------------------------------------------------------
SERVER_NAME=localhost
SERVER_PORT=8080

# Log level: info | debug
LOG_LEVEL=info

# ---- Storage ---------------------------------------------------------------
# One of: local | s3 | gcs | azure
STORAGE_TYPE=local

# Local: root directory where files are stored
# Use a relative path for local dev; override to /data in Docker.
LOCAL_DATA_PATH=./webdav-data

# S3 (required when STORAGE_TYPE=s3)
#S3_BUCKET=my-webdav-bucket
#S3_REGION=us-east-1
#S3_PREFIX=webdav/            # optional key prefix
#S3_ENDPOINT=                 # custom endpoint for MinIO/LocalStack
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=

# GCS (required when STORAGE_TYPE=gcs)
#GCS_BUCKET=my-webdav-bucket
#GCS_PREFIX=webdav/
#GOOGLE_APPLICATION_CREDENTIALS=/secrets/sa.json  # leave empty for ADC

# Azure Blob Storage (required when STORAGE_TYPE=azure)
# Either set AZURE_STORAGE_CONNECTION_STRING (recommended for Azurite),
# or AZURE_STORAGE_ACCOUNT + AZURE_STORAGE_KEY.
#AZURE_CONTAINER=webdav
#AZURE_PREFIX=webdav/
#AZURE_STORAGE_ACCOUNT=
#AZURE_STORAGE_KEY=
#AZURE_STORAGE_ENDPOINT=        # override service URL (Azure Stack, Azurite without conn string)
#AZURE_STORAGE_CONNECTION_STRING=

# ---- Folder permissions ----------------------------------------------------
# Format: /path:users:mode[,/path:users:mode,...]
#   users: public | * | alice bob | * !charlie
#   mode:  ro | rw
#
# Examples:
#   Public read-only + authenticated read-write:
#     FOLDER_PERMISSIONS=/public:public:ro,/files:*:rw
#
#   Per-user isolation:
#     FOLDER_PERMISSIONS=/alice:alice:rw,/bob:bob:rw,/shared:*:ro
#
#   Everyone except charlie:
#     FOLDER_PERMISSIONS=/files:* !charlie:rw
#
FOLDER_PERMISSIONS="/public:public:ro,/private:*:ro,/:alice:rw"

# Automatically create missing folders at startup (local storage only).
AUTO_CREATE_FOLDERS=true

# ---- HTTP methods ----------------------------------------------------------
RO_METHODS="GET HEAD OPTIONS PROPFIND"
RW_METHODS="GET HEAD OPTIONS PROPFIND PUT DELETE MKCOL COPY MOVE LOCK UNLOCK PROPPATCH"

# ---- Authentication --------------------------------------------------------

# Basic auth (htpasswd-style, passwords compared via bcrypt)
BASIC_AUTH_ENABLED=true
# Format: "user1:pass1 user2:pass2"
BASIC_USERS="alice:alice123 bob:bob123"

# LDAP / Active Directory
LDAP_ENABLED=false
#LDAP_URL=ldaps://ldap.company.com
#LDAP_BASE_DN=ou=users,dc=company,dc=com
#LDAP_BIND_DN=uid=searchuser,ou=users,dc=company,dc=com
#LDAP_BIND_PASSWORD=securepassword
#LDAP_ATTRIBUTE=uid           # sAMAccountName for AD
#LDAP_STARTTLS=false

# OAuth 2.0 / OpenID Connect (Bearer token validation)
OAUTH_ENABLED=false
#OIDC_PROVIDER_URL=https://keycloak.example.com/realms/myrealm
#OIDC_CLIENT_ID=webdav-client
#OIDC_CLIENT_SECRET=secret
#OIDC_REDIRECT_URL=https://files.example.com/oidc/callback
#OIDC_SCOPES=openid email profile
#OIDC_USERNAME_CLAIM=preferred_username

# ---- Features --------------------------------------------------------------

# CORS (useful when accessed from a browser-based WebDAV client)
CORS_ENABLED=false
#CORS_ORIGIN=https://myapp.example.com
#CORS_ALLOWED_METHODS=GET,HEAD,PUT,DELETE,MKCOL,COPY,MOVE,OPTIONS,PROPFIND,PROPPATCH,LOCK,UNLOCK
#CORS_ALLOWED_HEADERS=Authorization,Content-Type,Depth,If,Lock-Token,Overwrite,Timeout,Destination

# Block web browser access (deny User-Agent containing "Mozilla")
BROWSER_ACCESS_BLOCKED=false
